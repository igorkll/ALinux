[
    {
        "type": "directory",
        "name": "sysroot1",
        "export": false,

        "directories": [
            ["/usr", [0, 0, "755"]]
        ],

        "items": [
            ["kernel_headers", "/usr"]
        ]
    },

    // --------------------------------- glibc
    {
        "type": "build-configure-make",
        "name": "glibc",
        "export": false,

        "sysroot": "sysroot1",
        "sysroot_field_name": "with-sysroot",

        "source": "source_glibc",
        "prefix": "/usr",

        "CFLAGS": [
            "-U_FORTIFY_SOURCE",
            "-O2"
        ],
        "LDFLAGS": [],
        "FLAGS": ["--disable-nls", "--disable-cet", "--disable-werror"]
    },
    {
        "type": "directory",
        "name": "sysroot2",
        "export": false,

        "items": [
            ["sysroot1", "/"],
            ["glibc", "/"]
        ]
    },

    // --------------------------------- ncurses
    {
        "type": "build-configure-make",
        "name": "ncurses",
        "export": false,

        "sysroot": "sysroot2",
        "sysroot_field_name": "with-sysroot",

        "source": "source_ncurses",
        "prefix": "/usr",

        "CFLAGS": [],
        "LDFLAGS": [],
        "FLAGS": ["--with-shared", "--without-cxx", "--without-cxx-binding", "--without-ada"]
    },
    {
        "type": "directory",
        "name": "sysroot",
        "export": false,

        "items": [
            ["sysroot2", "/"],
            ["ncurses", "/"]
        ]
    }
]
