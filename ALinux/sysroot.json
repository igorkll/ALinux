[
    {
        "type": "directory",
        "name": "sysroot1",
        "export": false,

        "directories": [
            ["/usr", [0, 0, "755"]]
        ],

        "items": [
            ["kernel_headers", "/usr"]
        ]
    },

    // --------------------------------- glibc
    {
        "type": "download",
        "name": "source_glibc.tar.gz",
        "export": false,

        "url": "https://ftp.gnu.org/gnu/glibc/glibc-2.39.tar.gz"
    },
    {
        "type": "unpack-tar-gz",
        "name": "source_glibc",

        "strip_components": 1,

        "archive": "source_glibc.tar.gz"
    },
    {
        "type": "build-configure-make",
        "name": "glibc",
        "export": false,

        "sysroot": "sysroot1",
        "sysroot_field_name": "with-sysroot",

        "source": "source_glibc",
        "prefix": "/usr",

        "CFLAGS": [
            "-U_FORTIFY_SOURCE",
            "-O2"
        ],
        "LDFLAGS": [],
        "FLAGS": ["--disable-nls", "--disable-cet", "--disable-werror"]
    },
    {
        "type": "directory",
        "name": "sysroot2",
        "export": false,

        "items": [
            ["sysroot1", "/"],
            ["glibc", "/"]
        ]
    },

    // --------------------------------- ncurses
    {
        "type": "download",
        "name": "source_ncurses.tar.gz",
        "export": false,

        "url": "https://ftp.gnu.org/gnu/ncurses/ncurses-6.5.tar.gz"
    },
    {
        "type": "unpack-tar-gz",
        "name": "source_ncurses",

        "strip_components": 1,

        "archive": "source_ncurses.tar.gz"
    },
    {
        "type": "build-configure-make",
        "name": "ncurses",
        "export": false,

        "sysroot": "sysroot2",
        "sysroot_field_name": "with-sysroot",

        "source": "source_ncurses",
        "prefix": "/usr",

        "CFLAGS": [],
        "LDFLAGS": [],
        "FLAGS": ["--with-shared", "--without-cxx", "--without-cxx-binding", "--without-ada", "--enable-pc-files", "--with-pkg-config-libdir=/usr/lib/pkgconfig"]
    },
    {
        "type": "directory",
        "name": "sysroot",
        "export": false,

        "items": [
            ["sysroot2", "/"],
            ["ncurses", "/"]
        ]
    }
]
