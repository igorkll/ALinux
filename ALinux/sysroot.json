[
    {
        "type": "directory",
        "name": "sysroot1",
        "export": false,

        "directories": [
            ["/usr", [0, 0, "755"]]
        ],

        "items": [
            ["kernel_headers", "/usr"]
        ]
    },
    {
        "type": "build-configure-make",
        "name": "glibc",
        "export": false,

        "sysroot": "sysroot1",
        "sysroot_field_name": "with-sysroot",

        "source": "source_glibc",
        "prefix": "/usr",

        "CFLAGS": [
            "-U_FORTIFY_SOURCE",
            "-O2"
        ],
        "LDFLAGS": [],
        "FLAGS": ["--disable-cet", "--disable-werror"]
    },
    {
        "type": "directory",
        "name": "sysroot",
        "export": false,

        "items": [
            ["glibc", "/"]
        ]
    }
]
