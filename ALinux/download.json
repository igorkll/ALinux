[
    // lua
    {
        "type": "download",
        "name": "source_lua.tar.gz",
        "export": false,

        "url": "https://lua.org/ftp/lua-5.3.6.tar.gz"
    },
    {
        "type": "unpack-tar-gz",
        "name": "source_unpacked_lua",

        "strip_components": 1,

        "archive": "source_lua.tar.gz"
    },
    {
        "type": "from-directory",
        "name": "source_lua",
        "export": false,

        "source": "source_unpacked_lua",
        "path": "/src"
    },

