{
    "architectures": [
        "i386"
    ],

    "builditems": [
        {
            "type": "include",
            "file": "kernel.json"
        },
        {
            "type": "include",
            "file": "sysroot.json"
        },

        // --------------------------------- packages
        {
            "type": "include",
            "file": "packages/lua.json"
        },
        {
            "type": "include",
            "file": "packages/bash.json"
        },
        {
            "type": "include",
            "file": "packages/coreutils.json"
        },
        {
            "type": "include",
            "file": "packages/util-linux.json"
        },
        {
            "type": "include",
            "file": "packages/grep.json"
        },
        {
            "type": "include",
            "file": "packages/sed.json"
        },
        {
            "type": "include",
            "file": "packages/findutils.json"
        },

        // --------------------------------- rootfs
        {
            "type": "directory",
            "name": "rootfs",
            "export": false,

            "directories": [
                ["/boot", [0, 0, "755"]],
                ["/home", [0, 0, "755"]]
            ],

            "items": [
                ["sysroot", "/"],
                ["kernel.img", "/boot/kernel.img"],

                ["files/init", "/init", [0, 0, "755"]],
                ["files/session", "/bin/session", [0, 0, "755"]],

                ["lua", "/"],
                ["bash", "/"],
                ["coreutils", "/"],
                ["util_linux", "/"],
                ["grep", "/"],
                ["sed", "/"],
                ["findutils", "/"]
            ],

            "move_after_items": [
                ["/bin", "/usr/bin"],
                ["/lib", "/usr/lib"]
            ],

            "symlinks_after_items": [
                ["/usr/bin", "/bin"],
                ["/usr/lib", "/lib"]
            ],

            "delete": [
                "/usr/include",
                "/usr/bin/bashbug",
                "/usr/share/doc",
                "/usr/share/man",
                "/usr/share/info",
                "/usr/share/locale",
                "/usr/share/i18n",
                "/var"
            ]
        },
        {
            "type": "filesystem",
            "name": "rootfs.img",
            "export": false,

            "source": "rootfs",

            "fs_type": "ext4",
            "size": "256MB",
            "label": "rootfs"
        },
        
        // --------------------------------- bootable image (BIOS)
        {
            "type": "full-disk-image",
            "name": "ALinux.img",
            "export": true,

            "size": "auto + (1 * 1024 * 1024)",

            "partitionTable": "dos",
            "partitions": [
                ["rootfs.img", "linux"]
            ],

            "bootloader": {
                "type": "grub",
                "config": "grub_fastboot.cfg",
                "boot": 0,
                "modules": [
                    "normal",
                    "part_msdos",
                    "ext2",
                    "configfile"
                ]
            }
        }
    ]
}
