{
    "architectures": [
        "i386"
    ],

    "builditems": [
        {
            "type": "include",
            "file": "download.json"
        },
        {
            "type": "include",
            "file": "kernel.json"
        },
        {
            "type": "include",
            "file": "sysroot.json"
        },
        {
            "type": "include",
            "file": "packages.json"
        },

        // --------------------------------- rootfs
        {
            "type": "directory",
            "name": "rootfs",
            "export": false,

            "directories": [
                ["/boot", [0, 0, "755"]],
                ["/bin", [0, 0, "755"]],
                ["/home", [0, 0, "755"]]
            ],

            "items": [
                ["sysroot", "/"],

                ["kernel.img", "/boot/kernel.img"],
                ["init", "/init", [0, 0, "755"]],

                ["lua", "/bin/lua", [0, 0, "755"]],
                ["luac", "/bin/luac", [0, 0, "755"]],

                ["coreutils", "/"],
                ["util_linux", "/"],
                ["bash", "/"]
            ],

            "delete": [
                "/usr/include",
                "/usr/bin/bashbug",
                "/usr/share/doc",
                "/usr/share/man",
                "/usr/share/info",
                "/usr/share/locale",
                "/usr/share/i18n",
                "/var"
            ]
        },
        {
            "type": "filesystem",
            "name": "rootfs.img",
            "export": false,

            "source": "rootfs",

            "fs_type": "ext4",
            "size": "512MB",
            "label": "rootfs"
        },
        
        // --------------------------------- bootable image (BIOS)
        {
            "type": "full-disk-image",
            "name": "ALinux.img",
            "export": true,

            "size": "auto + (1 * 1024 * 1024)",

            "partitionTable": "dos",
            "partitions": [
                ["rootfs.img", "linux"]
            ],

            "bootloader": {
                "type": "grub",
                "config": "grub_fastboot.cfg",
                "boot": 0,
                "modules": [
                    "normal",
                    "part_msdos",
                    "ext2",
                    "configfile"
                ]
            }
        }
    ]
}
